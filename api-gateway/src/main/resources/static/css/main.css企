/* CrewCanvas - Premium Responsive Design System */
:root {
    --primary-orange: #ff8c00;
    --accent-red: #ff4c3b;
    --sidebar-bg: #1a1b1e;
    --content-bg: #ffffff;
    --white: #ffffff;
    --text-dark: #1f2937;
    --text-muted: #6b7280;
    --sidebar-text: #9ca3af;
    --nav-active-gradient: linear-gradient(90deg, #ff8c00, #ff4c3b);
    --shadow-premium: 0 10px 40px rgba(0, 0, 0, 0.08);
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Inter', -apple-system, sans-serif;
}

body {
    background-color: var(--content-bg);
    color: var(--text-dark);
    min-height: 100vh;
}

/* --- SIDEBAR (Desktop: 1025px+) --- */
.sidebar {
    position: fixed;
    top: 0;
    left: 0;
    width: 280px;
    height: 100vh;
    background: #1a1b1e;
    padding: 40px 0;
    z-index: 1000;
    display: none; /* Hidden by default (Mobile) */
}

.sidebar .brand {
    padding: 0 32px;
    margin-bottom: 40px;
}

.sidebar .brand h2 {
    color: var(--white);
    font-size: 24px;
    font-weight: 800;
}

.sidebar .brand p {
    font-size: 11px;
    color: #666;
    font-style: italic;
}

.sidebar .nav-menu {
    display: flex;
    flex-direction: column;
    padding: 0 16px;
}

.sidebar .nav-item {
    display: flex;
    align-items: center;
    padding: 16px 24px;
    color: #94a3b8;
    text-decoration: none;
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 8px;
    border-radius: 14px;
    transition: 0.3s;
}

.sidebar .nav-item:hover { color: white; background: rgba(255,255,255,0.05); }

.sidebar .nav-item.active {
    background: var(--nav-active-gradient);
    color: white;
    box-shadow: 0 8px 16px rgba(255, 140, 0, 0.2);
}

.sidebar .nav-item .icon { font-size: 20px; margin-right: 15px; }

/* --- BOTTOM NAV (Mobile: Up to 1024px) --- */
.bottom-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 65px;
    background: #111;
    display: flex;
    justify-content: space-around;
    align-items: center;
    z-index: 1000;
    border-top: 1px solid rgba(255,255,255,0.1);
}

.bottom-nav .nav-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #888;
    text-decoration: none;
    font-size: 9px;
    gap: 3px;
}

.bottom-nav .nav-item .icon { font-size: 22px; }
.bottom-nav .nav-item.active { color: var(--primary-orange); }

/* --- MAIN CONTENT & HEADER --- */
.main-content {
    width: 100%;
    min-height: 100vh;
}

.top-header {
    width: 100%;
    padding: 20px 40px;
    display: flex;
    justify-content: flex-end;
    align-items: center;
}

.status-bar {
    display: flex;
    gap: 15px;
    align-items: center;
}

.user-profile-box {
    width: 42px;
    height: 42px;
    background: #e2e8f0;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    cursor: pointer;
}
.user-profile-box::after { content: 'US'; font-weight: 800; font-size: 13px; color: #475569; }

/* Profile Dropdown */
.profile-dropdown-menu {
    display: none;
    position: absolute;
    top: 55px;
    right: 0;
    width: 200px;
    background: white;
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    border-radius: 12px;
    padding: 10px;
    z-index: 2000;
}
.profile-dropdown-menu.active { display: block; }
.dropdown-item {
    display: block;
    padding: 12px;
    color: var(--text-dark);
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    border-radius: 8px;
}
.dropdown-item:hover { background: #f8fafc; color: var(--primary-orange); }

/* --- RESPONSIVE LOGIC --- */
@media (min-width: 1080px) {
    .sidebar { display: block; }
    .bottom-nav { display: none; }
    .main-content { margin-left: 280px; width: calc(100% - 280px); }
    padding: 20px 40px;
}

@media (max-width: 1080px) {
    .main-content { padding-bottom: 80px; }
    .top-header { padding: 15px 20px; }
    .top-header::before { content: 'CrewCanvas'; color: var(--primary-orange); font-weight: 800; font-size: 20px; }
}

.content-body { padding: 20px; }
.card { background: white; border-radius: 16px; padding: 20px; box-shadow: var(--shadow-premium); }

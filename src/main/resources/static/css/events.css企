/* Events Page - Balanced Responsive Design */

/* Horizontal Tab System */
.horizontal-cards {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    padding: 10px 5px 30px;
    scrollbar-width: none;
    -ms-overflow-style: none;
}

.horizontal-cards::-webkit-scrollbar {
    display: none;
}

.event-feature-card {
    min-width: 260px;
    background: var(--white);
    border-radius: 20px;
    padding: 20px 24px;
    display: flex;
    align-items: center;
    gap: 16px;
    box-shadow: var(--shadow-premium);
    border: 1px solid #f1f5f9;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.event-feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
}

.event-feature-card.active {
    background: var(--nav-active-gradient);
    border-color: transparent;
    color: white;
}

.icon-box {
    width: 54px;
    height: 54px;
    border-radius: 14px;
    background: #f8fafc;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    flex-shrink: 0;
}

.event-feature-card.active .icon-box {
    background: rgba(255, 255, 255, 0.2);
    color: white;
}

.info h3 { font-size: 14px; font-weight: 800; margin: 0; text-transform: uppercase; letter-spacing: 0.5px; }
.info p { font-size: 11px; opacity: 0.8; margin: 2px 0 0; }

.event-feature-card.active .info h3,
.event-feature-card.active .info p { color: white; }

.badge {
    font-size: 18px;
    font-weight: 800;
    color: var(--primary-orange);
    margin-left: auto;
}

.event-feature-card.active .badge { color: white; }

/* Grid System */
.events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 24px;
    margin-top: 10px;
}

/* Floating Action Button */
.fab {
    position: fixed;
    bottom: 30px;
    right: 30px;
    width: 65px;
    height: 65px;
    background: var(--nav-active-gradient);
    color: white;
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 30px;
    box-shadow: 0 10px 25px rgba(255, 76, 59, 0.3);
    cursor: pointer;
    transition: all 0.3s;
    border: none;
    z-index: 1000;
}

.fab:hover { transform: scale(1.08) rotate(90deg); }

/* Choice Modal Grid */
.choices-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-top: 20px;
}

.choice-item {
    padding: 24px;
    border-radius: 16px;
    background: #f8fafc;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    transition: 0.2s;
    border: 1px solid #f1f5f9;
}

.choice-item:hover {
    background: white;
    border-color: var(--primary-orange);
    transform: translateY(-5px);
    box-shadow: var(--shadow-premium);
}

.choice-icon { font-size: 30px; }

/* Responsive Adjustments */
@media (max-width: 1024px) {
    .events-grid { grid-template-columns: 1fr; }
    .fab { bottom: 100px; right: 20px; width: 55px; height: 55px; font-size: 24px; }
}

@media (max-width: 600px) {
    .choices-grid { grid-template-columns: 1fr; }
    .modal-content { padding: 30px 20px; }
}
